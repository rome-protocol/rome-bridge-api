    "dotenv-flow": "^4.1.0",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "pino": "^9.2.0",
    "prom-client": "^15.1.0",
    "viem": "^2.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
