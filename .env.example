# rome-bridge-api environment configuration template.
# Copy to .env (or .env.local) for local dev; production deployments
# inject these via process manager / orchestrator env.

# ── Required ───────────────────────────────────────────────────────────────

# Redis connection URL. ioredis-compatible.
REDIS_URL=redis://localhost:6379

# Absolute path to a local clone of rome-protocol/rome-registry.
# Chain metadata (chainIds, contract addresses, gas mints, bridge wiring) is
# canonical there per the Rome registry. The service refuses to boot without it.
REGISTRY_PATH=/absolute/path/to/your/registry/clone

# ── Required for non-test environments ─────────────────────────────────────

# Ethereum RPC URL used for source-tx verification (Sepolia for devnet, mainnet
# for prod). viem-compatible.
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/your-key

# ── Optional ───────────────────────────────────────────────────────────────

# HTTP listen port. Default 3000.
PORT=3000

# development | test | staging | production. Default development.
NODE_ENV=development

# trace | debug | info | warn | error. Default info.
LOG_LEVEL=info

# sepolia | mainnet. Default sepolia.
ETHEREUM_NETWORK=sepolia

# Override the Circle IRIS attestation endpoint. Default is Circle's sandbox.
# CIRCLE_IRIS_BASE_URL=https://iris-api-sandbox.circle.com/v1

# Override the Wormholescan endpoint. Default flips by ETHEREUM_NETWORK.
# WORMHOLESCAN_BASE_URL=https://api.testnet.wormholescan.io

# Solana RPC URL. Default Solana devnet public RPC.
# SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Test-only ──────────────────────────────────────────────────────────────

# Set to "1" to swap real Redis for ioredis-mock in test runs.
# BRIDGE_API_USE_IN_MEMORY_REDIS=1

# ── Sponsor worker (separate process; not the API) ─────────────────────────

# These are read by the separate sponsor worker, never by the API process.
# SPONSOR_KEYPAIR_PATH=/opt/rome/sponsor-keypair.json
# BRIDGE_API_URL=http://localhost:3000
# SPONSOR_CU_LIMIT=400000
